# PostgreSQL production example: postgresql+asyncpg://netradar:change-me@localhost/netradar
DATABASE_URL=sqlite+aiosqlite:///./netradar.db
POLL_INTERVAL_SECONDS=60
PING_TIMEOUT_SECONDS=2
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
# Leave blank in local development to log notification attempts without sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=netradar@oic.local
SMTP_USE_TLS=true
SMS_GATEWAY_URL=
SMS_API_KEY=
DASHBOARD_URL=http://127.0.0.1:5500
LEVEL_2_ESCALATION_MINUTES=60
# Use unprivileged ports locally. Production may use 514/162 when the service account is permitted.
SYSLOG_PORT=5514
SNMP_TRAP_PORT=1162
PASSIVE_SOURCE_ALLOWLIST=
# Phase 4 security: set true in production and replace every example secret.
AUTH_REQUIRED=false
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=netradar-admin
ADMIN_PASSWORD=change-before-production
SERVICE_API_KEY=replace-with-a-separate-service-api-key
IT_SUPPORT_WEBHOOK_URL=
HEARTBEAT_INTERVAL_SECONDS=30
